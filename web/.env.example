# Copy this file to .env.local and fill in your project values.
# .env.local is gitignored — never commit real keys.

# Your project URL from Supabase (Settings → API)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Your project's PUBLISHABLE key (Settings → API → Publishable and secret API keys)
# Publishable keys are safe to expose in the browser when RLS is configured.
# Do NOT put your secret key here.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
